itle": String("Result"), "type": String("array")}}, "required": Array [String("result")], "title": String("source_searchOutput"), "type": String("object")}), annotations: None, icons: None, meta: None }, Tool { name: "source_tags", title: None, description: Some("List all auto-detected topics with video counts.\n\nTags are assigned automatically via zero-shot embedding similarity\nduring video indexing. Shared across videos — enables topic clustering.\n\nArgs:\n    source: Source name (default: \"youtube\")\n"), input_schema: {"properties": Object {"source": Object {"default": String("youtube"), "title": String("Source"), "type": String("string")}}, "title": String("source_tagsArguments"), "type": String("object")}, output_schema: Some({"properties": Object {"result": Object {"items": Object {"additionalProperties": Bool(true), "type": String("object")}, "title": String("Result"), "type": String("array")}}, "required": Array [String("result")], "title": String("source_tagsOutput"), "type": String("object")}), annotations: None, icons: None, meta: None }, Tool { name: "source_related", title: None, description: Some("Find related videos by shared tags.\n\nGiven a video URL, finds other videos that share auto-detected topics.\nReturns videos sorted by number of shared tags (most related first).\n\nArgs:\n    video_url: YouTube video URL or video ID\n    source: Source name (default: \"youtube\")\n"), input_schema: {"properties": Object {"source": Object {"default": String("youtube"), "title": String("Source"), "type": String("string")}, "video_url": Object {"title": String("Video Url"), "type": String("string")}}, "required": Array [String("video_url")], "title": String("source_relatedArguments"), "type": String("object")}, output_schema: Some({"properties": Object {"result": Object {"items": Object {"additionalProperties": Bool(true), "type": String("object")}, "title": String("Result"), "type": String("array")}}, "required": Array [String("result")], "title": String